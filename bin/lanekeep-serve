#!/usr/bin/env bash
set -euo pipefail

LANEKEEP_DIR="$(cd "$(dirname "$0")/.." && pwd)"

# --- Dependency checks ---
for dep in jq socat; do
  if ! command -v "$dep" >/dev/null 2>&1; then
    echo "Error: '$dep' is required but not installed." >&2
    echo "Install it with: sudo apt install $dep" >&2
    exit 1
  fi
done

# --- Parse arguments ---
SPEC_FILE=""
while [ $# -gt 0 ]; do
  case "$1" in
    --spec) SPEC_FILE="$2"; shift 2 ;;
    *) echo "Unknown option: $1" >&2; exit 1 ;;
  esac
done

# --- Resolve paths ---
PROJECT_DIR="${PROJECT_DIR:-$(pwd 2>/dev/null || echo "$PWD")}"
SOCKET="${LANEKEEP_SOCKET:-$PROJECT_DIR/.lanekeep/lanekeep.sock}"

# Validate socket path length (Unix limit: 108 bytes)
if [ ${#SOCKET} -gt 108 ]; then
  echo "Error: Socket path too long (${#SOCKET} > 108 bytes): $SOCKET" >&2
  echo "Fix: set LANEKEEP_SOCKET to a shorter path, e.g. /tmp/lanekeep-\$PROJECT.sock" >&2
  exit 1
fi

# --- Prevent duplicate listeners ---
PIDFILE="$(dirname "$SOCKET")/lanekeep-serve.pid"
LOCKFILE="$(dirname "$SOCKET")/lanekeep-serve.lock"
(umask 077 && mkdir -p "$(dirname "$SOCKET")")

exec 7>"$LOCKFILE"
if ! flock -n 7; then
  echo "[LaneKeep] ERROR: sidecar already running (lock held)" >&2
  echo "[LaneKeep] Run: lanekeep stop" >&2
  exec 7>&-
  exit 1
fi

if [ -f "$PIDFILE" ]; then
  OLD_SHELL_PID=$(head -1 "$PIDFILE" 2>/dev/null)
  OLD_SOCAT_PID=$(sed -n '2p' "$PIDFILE" 2>/dev/null)
  if [ -n "$OLD_SHELL_PID" ] && kill -0 "$OLD_SHELL_PID" 2>/dev/null; then
    echo "[LaneKeep] ERROR: sidecar already running (pid $OLD_SHELL_PID)" >&2
    echo "[LaneKeep] Run: lanekeep stop  or  kill $OLD_SHELL_PID" >&2
    exec 7>&-
    exit 1
  fi
  # Shell is dead — kill orphaned socat if present
  if [ -n "$OLD_SOCAT_PID" ] && kill -0 "$OLD_SOCAT_PID" 2>/dev/null; then
    kill "$OLD_SOCAT_PID" 2>/dev/null || true
    # Wait up to 0.5s for socat to exit
    for _i in 1 2 3 4 5; do
      kill -0 "$OLD_SOCAT_PID" 2>/dev/null || break
      sleep 0.1
    done
  fi
  rm -f "$PIDFILE"
fi

# Socket-based fallback: kill any remaining listener from pre-fix PID files
if [ -S "$SOCKET" ]; then
  ORPHAN_PID=$(lsof -t "$SOCKET" 2>/dev/null || true)
  if [ -n "$ORPHAN_PID" ]; then
    kill "$ORPHAN_PID" 2>/dev/null || true
    sleep 0.2
  else
    # Stale socket — no process listening. Clean it up.
    rm -f "$SOCKET"
  fi
fi

# --- Load config, parse spec, initialize session ---
# shellcheck source=/dev/null
source "$LANEKEEP_DIR/lib/config.sh"
load_config "$PROJECT_DIR" "$SPEC_FILE"

# --- AG-004: Generate correlation ID for cross-worktree trace correlation ---
_canonical_project=$(cd "$PROJECT_DIR" && pwd -P)
LANEKEEP_CORRELATION_ID=$(printf '%s' "$_canonical_project" | sha256sum | cut -c1-16)
export LANEKEEP_CORRELATION_ID
_SOCKET_REGISTRY="${XDG_STATE_HOME:-$HOME/.local/state}/lanekeep/sockets"

# --- Cache plugin hashes at startup for handler performance (1D) ---
PLUGIN_DIR="$LANEKEEP_DIR/plugins.d"
if [ -d "$PLUGIN_DIR" ]; then
  _cached=""
  for p in "$PLUGIN_DIR"/*.plugin.sh "$PLUGIN_DIR"/*.plugin.py \
           "$PLUGIN_DIR"/*.plugin.js "$PLUGIN_DIR"/*.plugin; do
    [ -f "$p" ] || continue
    _h=$(sha256sum "$p" 2>/dev/null | cut -d' ' -f1)
    _n=$(basename "$p")
    [ -n "$_cached" ] && _cached="${_cached};"
    _cached="${_cached}${_n}=${_h}"
  done
  export LANEKEEP_PLUGIN_HASHES="$_cached"
fi

# --- Watchdog configuration ---
_WATCHDOG_ENABLED=1
if [ "${LANEKEEP_NO_WATCHDOG:-}" = "1" ]; then
  _WATCHDOG_ENABLED=0
fi
_WATCHDOG_MAX_RESTARTS=${LANEKEEP_WATCHDOG_MAX_RESTARTS:-5}
_WATCHDOG_BACKOFF_CAP=30
_WATCHDOG_STABLE_THRESHOLD=60
_SHUTTING_DOWN=0

# --- Prepare socket (VULN-10: restrict permissions to owner only) ---
rm -f "$SOCKET"

# --- Start Ralph watcher in background ---
RALPH_PID=""
if [ -d "$PROJECT_DIR/.ralph" ]; then
  if [ -x "$LANEKEEP_DIR/lib/ralph-context.sh" ]; then
    "$LANEKEEP_DIR/lib/ralph-context.sh" watch "$PROJECT_DIR/.ralph" &
    RALPH_PID=$!
  fi
fi

# --- Cleanup trap ---
SOCAT_PID=""
cleanup() {
  _SHUTTING_DOWN=1
  if [ -n "$SOCAT_PID" ] && kill -0 "$SOCAT_PID" 2>/dev/null; then
    kill "$SOCAT_PID" 2>/dev/null || true
    wait "$SOCAT_PID" 2>/dev/null || true
  fi
  rm -f "$SOCKET" "$PIDFILE" "$LOCKFILE"
  rm -f "${_SOCKET_REGISTRY:-}/${LANEKEEP_CORRELATION_ID:-}.sock"
  if [ -n "$RALPH_PID" ] && kill -0 "$RALPH_PID" 2>/dev/null; then
    kill "$RALPH_PID" 2>/dev/null || true
  fi
}
trap cleanup EXIT INT TERM HUP

# VULN-10: Set umask before socat creates socket to restrict to owner-only
SOCAT_T=$(( ${LANEKEEP_HOOK_TIMEOUT:-2} + 1 ))
_SERVE_LOG="$(dirname "$SOCKET")/lanekeep-serve.log"

# --- Start server ---
echo "[LaneKeep] Project:     $PROJECT_DIR"
echo "[LaneKeep] Session:     $LANEKEEP_SESSION_ID (pid $$)"
echo "[LaneKeep] Correlation: $LANEKEEP_CORRELATION_ID"
echo "[LaneKeep] Trace:       $LANEKEEP_TRACE_FILE"
echo "[LaneKeep] Diag log:    $_SERVE_LOG"

_start_socat() {
  rm -f "$SOCKET"
  (umask 077 && exec socat -lf "$_SERVE_LOG" -t "$SOCAT_T" \
    UNIX-LISTEN:"$SOCKET",fork,unlink-early,backlog=128 \
    EXEC:"$LANEKEEP_DIR/bin/lanekeep-handler",pipes) &
  SOCAT_PID=$!
  printf '%s\n%s\n' "$$" "$SOCAT_PID" > "$PIDFILE"
}

_start_socat

# Register socket in XDG state dir for cross-worktree discovery (AG-004)
(install -d -m 0700 "$_SOCKET_REGISTRY" && \
  ln -sf "$(readlink -f "$SOCKET" 2>/dev/null || printf '%s' "$SOCKET")" \
    "$_SOCKET_REGISTRY/${LANEKEEP_CORRELATION_ID}.sock") 2>/dev/null || true

# Verify socat started
for _v in 1 2 3 4 5; do
  kill -0 "$SOCAT_PID" 2>/dev/null && break
  sleep 0.1
done
if ! kill -0 "$SOCAT_PID" 2>/dev/null; then
  echo "[LaneKeep] ERROR: socat failed to start" >&2
  exit 1
fi

if [ "$_WATCHDOG_ENABLED" -eq 0 ]; then
  EXIT_CODE=0
  wait "$SOCAT_PID" || EXIT_CODE=$?
  if [ $EXIT_CODE -ne 0 ]; then
    echo "[LaneKeep] Sidecar stopped unexpectedly (exit code $EXIT_CODE)" >&2
  else
    echo "[LaneKeep] Sidecar stopped." >&2
  fi
  exit 0
fi

# --- Watchdog loop ---
_restart_count=0
_backoff=1

while true; do
  _start_time=$SECONDS

  EXIT_CODE=0
  wait "$SOCAT_PID" 2>/dev/null || EXIT_CODE=$?

  # Clean shutdown — do not restart
  if [ "$_SHUTTING_DOWN" -eq 1 ]; then
    echo "[LaneKeep] Sidecar stopped." >&2
    break
  fi

  # Exit code 0 means socat exited normally (not a crash)
  if [ $EXIT_CODE -eq 0 ]; then
    echo "[LaneKeep] Sidecar stopped." >&2
    break
  fi

  # --- Unexpected crash: attempt restart ---
  _runtime=$(( SECONDS - _start_time ))

  # If socat ran long enough, reset backoff and restart count
  if [ "$_runtime" -ge "$_WATCHDOG_STABLE_THRESHOLD" ]; then
    _restart_count=0
    _backoff=1
  fi

  _restart_count=$(( _restart_count + 1 ))
  if [ "$_restart_count" -gt "$_WATCHDOG_MAX_RESTARTS" ]; then
    echo "[LaneKeep] ERROR: socat crashed $_restart_count times — giving up" >&2
    echo "[LaneKeep] Last exit code: $EXIT_CODE" >&2
    exit 1
  fi

  echo "[LaneKeep] WARNING: socat crashed (exit $EXIT_CODE, uptime ${_runtime}s). Restarting in ${_backoff}s... ($_restart_count/$_WATCHDOG_MAX_RESTARTS)" >&2

  # Interruptible sleep — if SIGTERM arrives during backoff, cleanup trap fires
  sleep "$_backoff" &
  wait $! 2>/dev/null || true  # exit code doesn't matter for sleep

  # Signal may have arrived during backoff
  if [ "$_SHUTTING_DOWN" -eq 1 ]; then
    echo "[LaneKeep] Sidecar stopped." >&2
    break
  fi

  _start_socat

  # Verify restart succeeded
  for _v in 1 2 3 4 5; do
    kill -0 "$SOCAT_PID" 2>/dev/null && break
    sleep 0.1
  done
  if ! kill -0 "$SOCAT_PID" 2>/dev/null; then
    echo "[LaneKeep] ERROR: socat failed to restart" >&2
    continue
  fi

  echo "[LaneKeep] Socat restarted (pid $SOCAT_PID)." >&2

  # Exponential backoff with cap
  _backoff=$(( _backoff * 2 ))
  if [ "$_backoff" -gt "$_WATCHDOG_BACKOFF_CAP" ]; then
    _backoff=$_WATCHDOG_BACKOFF_CAP
  fi
done
